# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Outbound SIP trunk (registered with LiveKit, dialed by the worker)
LIVEKIT_SIP_TRUNK_ID=

# Twilio Elastic SIP Trunk — ONLY needed if you provision the trunk via
# scripts/provision_sip_trunk.py. If you create the trunk from the LiveKit
# Cloud console instead, leave these blank.
TWILIO_SIP_TRUNK_URI=
TWILIO_SIP_TRUNK_USERNAME=
TWILIO_SIP_TRUNK_PASSWORD=
TWILIO_PHONE_NUMBER=

# Inference providers
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Test phone
TEST_REP_PHONE_NUMBER=

# Tracing (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vera-spike
